rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/notes/{noteId}/images/{imageFile} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/notes/{noteId}/canvas/{canvasFile} {
      allow read, write: if isOwner(userId);
    }
  }
}
